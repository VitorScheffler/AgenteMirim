<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header / Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:paddingTop="24dp"
            android:background="#2E7D32"
            app:titleTextColor="#FFFFFF"
            app:title="Conteúdos"/>

        <!-- Lista de conteúdos -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerConteudos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="16dp"
            android:paddingBottom="88dp"/>

        <!-- Estado vazio -->
        <LinearLayout
            android:id="@+id/layoutVazio"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nenhum conteúdo disponível"
                android:textSize="14sp"
                android:textColor="#A5D6A7"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:indeterminateTint="#2E7D32"/>

    </LinearLayout>

    <!-- FAB: visível apenas para projeto e admin -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNovoConteudo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Novo conteúdo"
        app:backgroundTint="#2E7D32"
        app:tint="#FFFFFF"
        app:elevation="6dp"
        android:visibility="gone"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#FAFFFE"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="#2E7D32"
        app:itemTextColor="#2E7D32"
        app:labelVisibilityMode="labeled"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
