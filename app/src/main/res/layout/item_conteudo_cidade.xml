<?xml version="1.0" encoding="utf-8"?>
<!--
    item_conteudo_cidade.xml — NOVO
    Card de conteúdo na lista de uma cidade específica
    Destino: app/src/main/res/layout/item_conteudo_cidade.xml
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="top">

        <!-- Thumbnail da cidade/conteúdo -->
        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="80dp"
            android:layout_marginEnd="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivThumb"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"/>

            </androidx.cardview.widget.CardView>

            <!-- Badge de categoria -->
            <TextView
                android:id="@+id/txtBadge"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="top|start"
                android:layout_margin="5dp"
                android:paddingHorizontal="7dp"
                android:gravity="center"
                android:text="DICA"
                android:textSize="8sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_badge_categoria"/>

        </FrameLayout>

        <!-- Textos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Título -->
            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"/>

            <!-- Linha: chips de arquivo + tempo + data -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <!-- Chips de tipo de arquivo -->
                <LinearLayout
                    android:id="@+id/layoutChips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginEnd="6dp"/>

            </LinearLayout>

            <!-- Tempo + Data -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:alpha="0.4"
                    android:layout_marginEnd="3dp"/>

                <TextView
                    android:id="@+id/txtTempo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 min"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/ic_menu_today"
                    android:alpha="0.4"
                    android:layout_marginEnd="3dp"/>

                <TextView
                    android:id="@+id/txtData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#9E9E9E"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Bookmark -->
        <ImageView
            android:id="@+id/ivBookmark"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="6dp"
            android:src="@android:drawable/btn_star_big_off"
            android:alpha="0.3"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Salvar"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>
