<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7F5"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#2E7D32"
        app:titleTextColor="#FFFFFF"
        app:title="Nova cidade"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <!-- Card: dados da cidade -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Informações da cidade"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="16dp"/>

                    <!-- Nome -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutNome"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Nome da cidade *"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#C8E6C9"
                        app:boxBackgroundColor="#F9FBF9">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editNome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:padding="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Descrição -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutDescricao"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Descrição *"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#C8E6C9"
                        app:boxBackgroundColor="#F9FBF9">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editDescricao"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="3"
                            android:gravity="top"
                            android:textColor="#1A1A1A"
                            android:textSize="14sp"
                            android:padding="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: imagem de capa -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Foto da cidade"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Adicione uma foto para identificar a cidade na lista"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"
                        android:layout_marginBottom="14dp"/>

                    <!-- Preview da imagem selecionada -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardPreview"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/ivPreviewImagem"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Nome da imagem selecionada -->
                    <TextView
                        android:id="@+id/txtNomeImagem"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#2E7D32"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone"/>

                    <!-- Área de upload -->
                    <LinearLayout
                        android:id="@+id/layoutUploadImagem"
                        android:layout_width="match_parent"
                        android:layout_height="90dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_upload_area"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="#2E7D32"
                            android:alpha="0.6"
                            android:layout_marginBottom="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toque para selecionar a foto"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#388E3C"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JPG, PNG (máx. 10MB)"
                            android:textSize="11sp"
                            android:textColor="#A5D6A7"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botão salvar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="SALVAR CIDADE"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                app:backgroundTint="#2E7D32"
                app:cornerRadius="16dp"
                app:elevation="4dp"/>

            <TextView
                android:id="@+id/txtProgresso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:textSize="12sp"
                android:textColor="#66BB6A"
                android:visibility="gone"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                android:indeterminateTint="#2E7D32"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>