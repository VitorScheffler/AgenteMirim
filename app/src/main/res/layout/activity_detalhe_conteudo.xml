<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_detalhe_conteudo.xml
    Destino: app/src/main/res/layout/activity_detalhe_conteudo.xml
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7F5"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#2E7D32"
        app:contentInsetStart="0dp"
        app:contentInsetEnd="0dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="8dp">
            <ImageView
                android:id="@+id/btnVoltar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_media_previous"
                android:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:contentDescription="Voltar"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Detalhes do conteúdo"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
            <ImageView
                android:id="@+id/btnCompartilhar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_share"
                android:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:contentDescription="Compartilhar"/>
        </RelativeLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Conteúdo scrollável -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Badge + Título -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/txtBadgeDetalhe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DICA"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_badge_categoria"/>

                <TextView
                    android:id="@+id/txtTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:lineSpacingExtra="2dp"/>

                <!-- Meta: tempo, data, cidade -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        android:alpha="0.5"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:id="@+id/txtTempoLeitura"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 min de leitura"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"
                        android:layout_marginEnd="14dp"/>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_today"
                        android:alpha="0.5"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:id="@+id/txtData"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"
                        android:layout_marginEnd="14dp"/>

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_dialog_map"
                        android:alpha="0.5"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:id="@+id/txtCidade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Imagem de capa -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivCapaDetalhe"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#E8F5E9"/>

            </androidx.cardview.widget.CardView>

            <!-- Tabs: Sobre o conteúdo | Materiais e arquivos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tabSobre"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Sobre o conteúdo"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:background="@drawable/bg_tab_ativo"
                    android:clickable="true"
                    android:focusable="true"/>

                <View android:layout_width="8dp" android:layout_height="0dp"/>

                <TextView
                    android:id="@+id/tabMateriais"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Materiais e arquivos"
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:background="@drawable/bg_tab_inativo"
                    android:clickable="true"
                    android:focusable="true"/>

            </LinearLayout>

            <!-- ── PAINEL: Sobre o conteúdo ── -->
            <LinearLayout
                android:id="@+id/painelSobre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- Descrição -->
                <TextView
                    android:id="@+id/txtDescricao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:lineSpacingExtra="6dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Card: O que você vai aprender -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAprender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F1F8F1">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_agenda"
                                android:tint="#2E7D32"
                                android:layout_marginEnd="8dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="O que você vai aprender:"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#2E7D32"/>

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutTopicos"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Botões editar/apagar (projeto/admin) -->
                <LinearLayout
                    android:id="@+id/layoutAcoes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditar"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Editar"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        app:backgroundTint="#E8F5E9"
                        app:cornerRadius="12dp"
                        app:elevation="0dp"
                        app:strokeColor="#A5D6A7"
                        app:strokeWidth="1dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApagar"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Apagar"
                        android:textColor="#C62828"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        app:backgroundTint="#FFEBEE"
                        app:cornerRadius="12dp"
                        app:elevation="0dp"
                        app:strokeColor="#FFCDD2"
                        app:strokeWidth="1dp"/>

                </LinearLayout>

                <!-- Modo edição -->
                <LinearLayout
                    android:id="@+id/layoutEdicao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EDITANDO"
                                android:textSize="10sp"
                                android:textColor="#388E3C"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:layout_marginBottom="12dp"/>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutEditTitulo"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:hint="Título"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeColor="#C8E6C9"
                                app:boxBackgroundColor="#F9FBF9">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editTitulo"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textCapSentences"
                                    android:textColor="#1A1A1A"
                                    android:textSize="14sp"
                                    android:padding="14dp"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutEditDescricao"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="14dp"
                                android:hint="Descrição"
                                app:boxCornerRadiusTopStart="12dp"
                                app:boxCornerRadiusTopEnd="12dp"
                                app:boxCornerRadiusBottomStart="12dp"
                                app:boxCornerRadiusBottomEnd="12dp"
                                app:boxStrokeColor="#C8E6C9"
                                app:boxBackgroundColor="#F9FBF9">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editDescricao"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="textMultiLine|textCapSentences"
                                    android:minLines="3"
                                    android:gravity="top"
                                    android:textColor="#1A1A1A"
                                    android:textSize="14sp"
                                    android:padding="14dp"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnCancelarEdicao"
                                    android:layout_width="0dp"
                                    android:layout_height="46dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    android:text="Cancelar"
                                    android:textColor="#757575"
                                    android:textSize="13sp"
                                    app:backgroundTint="#F5F5F5"
                                    app:cornerRadius="12dp"
                                    app:elevation="0dp"/>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnSalvarEdicao"
                                    android:layout_width="0dp"
                                    android:layout_height="46dp"
                                    android:layout_weight="1"
                                    android:text="Salvar"
                                    android:textColor="#FFFFFF"
                                    android:textStyle="bold"
                                    android:textSize="13sp"
                                    app:backgroundTint="#2E7D32"
                                    app:cornerRadius="12dp"
                                    app:elevation="0dp"/>

                            </LinearLayout>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>

            <!-- ── PAINEL: Materiais e arquivos ── -->
            <LinearLayout
                android:id="@+id/painelMateriais"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:id="@+id/layoutArquivos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingVertical="8dp"/>

                </androidx.cardview.widget.CardView>

                <!-- Mensagem quando não há arquivos -->
                <TextView
                    android:id="@+id/txtSemArquivos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhum arquivo anexado a este conteúdo."
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- ProgressBar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:indeterminateTint="#2E7D32"/>

        </LinearLayout>
    </ScrollView>

    <!-- Rodapé -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompartilharRodape"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="8dp"
            android:text="Compartilhar conteúdo"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            app:backgroundTint="#2E7D32"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconTint="#FFFFFF"
            app:iconGravity="textStart"
            app:iconPadding="8dp"/>



    </LinearLayout>

</LinearLayout>
