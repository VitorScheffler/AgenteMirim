<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingTop="24dp"
        android:background="#2E7D32"
        app:titleTextColor="#FFFFFF"
        app:title="Criar Usuário"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FAFFFE">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DADOS DE ACESSO"
                        android:textSize="11sp"
                        android:textColor="#388E3C"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="16dp"/>

                    <!-- NOME -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NOME COMPLETO"
                        android:textSize="10sp"
                        android:textColor="#388E3C"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutNome"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#C8E6C9"
                        app:boxBackgroundColor="#F1F8E9">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editNome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Nome completo"
                            android:inputType="textPersonName"
                            android:textColor="#2E7D32"
                            android:textColorHint="#A5D6A7"
                            android:textSize="14sp"
                            android:padding="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- E-MAIL -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="E-MAIL"
                        android:textSize="10sp"
                        android:textColor="#388E3C"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutEmail"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#C8E6C9"
                        app:boxBackgroundColor="#F1F8E9">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="usuario@email.com"
                            android:inputType="textEmailAddress"
                            android:textColor="#2E7D32"
                            android:textColorHint="#A5D6A7"
                            android:textSize="14sp"
                            android:padding="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- SENHA -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SENHA INICIAL"
                        android:textSize="10sp"
                        android:textColor="#388E3C"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutSenha"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#C8E6C9"
                        app:boxBackgroundColor="#F1F8E9"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#81C784">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editSenha"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="mínimo 6 caracteres"
                            android:inputType="textPassword"
                            android:textColor="#2E7D32"
                            android:textColorHint="#A5D6A7"
                            android:textSize="14sp"
                            android:padding="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- PERFIL DE ACESSO -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PERFIL DE ACESSO"
                        android:textSize="10sp"
                        android:textColor="#388E3C"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="10dp"/>

                    <!-- Descrição dos perfis -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="👤 Usuário — acesso básico aos conteúdos\n📋 Projeto — cria e gerencia conteúdos\n🛡 Admin — acesso total ao sistema"
                        android:textSize="11sp"
                        android:textColor="#81C784"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="14dp"/>

                    <!-- Botões de perfil (3 colunas) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp">

                        <!-- Usuário -->
                        <LinearLayout
                            android:id="@+id/btnPerfilUsuario"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/bg_logo_circle"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView
                                android:id="@+id/txtPerfilUsuario"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="👤 Usuário"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"/>
                        </LinearLayout>

                        <!-- Projeto -->
                        <LinearLayout
                            android:id="@+id/btnPerfilProjeto"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/circle_light_green"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView
                                android:id="@+id/txtPerfilProjeto"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📋 Projeto"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#2E7D32"/>
                        </LinearLayout>

                        <!-- Admin -->
                        <LinearLayout
                            android:id="@+id/btnPerfilAdmin"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:background="@drawable/circle_light_green"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView
                                android:id="@+id/txtPerfilAdmin"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🛡 Admin"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#2E7D32"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divisória -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E8F5E9"
                        android:layout_marginBottom="20dp"/>

                    <!-- Botão criar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCriar"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="CRIAR USUÁRIO"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:letterSpacing="0.08"
                        app:backgroundTint="#2E7D32"
                        app:cornerRadius="14dp"
                        app:elevation="4dp"/>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        android:indeterminateTint="#2E7D32"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
