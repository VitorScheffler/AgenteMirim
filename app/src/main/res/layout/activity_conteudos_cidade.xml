<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_conteudos_cidade.xml — REDESENHADO
    Destino: app/src/main/res/layout/activity_conteudos_cidade.xml
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F5F0"
    android:fitsSystemWindows="true">

    <!-- ══════════════════════════════════════════
         HERO — imagem + overlay + controles
         ══════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="210dp">

        <!-- Foto de capa da cidade -->
        <ImageView
            android:id="@+id/ivCapaCidade"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_dialog_map"/>

        <!-- Gradiente escurecendo de cima p/ baixo -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_gradient_bottom"/>

        <!-- ── Top bar: voltar + filtrar + menu admin ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">

            <!-- Botão voltar circular com fundo translúcido -->
            <FrameLayout
                android:id="@+id/btnVoltar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_btn_voltar"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Voltar">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_media_previous"
                    android:tint="#FFFFFF"/>

            </FrameLayout>

            <!-- Espaço flexível -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <!-- Botão filtrar pill -->
            <LinearLayout
                android:id="@+id/btnFiltrar"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="14dp"
                android:background="@drawable/bg_btn_filtrar"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:tint="#FFFFFF"
                    android:layout_marginEnd="5dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Filtrar"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.02"/>

            </LinearLayout>

            <!-- ⋮ Botão de opções admin — visível só para admin via código -->
            <FrameLayout
                android:id="@+id/btnMenuAdmin"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_btn_voltar"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                android:contentDescription="Opções da cidade">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_more"
                    android:tint="#FFFFFF"/>

            </FrameLayout>

        </LinearLayout>

        <!-- ── Rodapé do hero: nome + brasão ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="bottom|center_vertical"
            android:padding="16dp">

            <!-- Textos -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtNomeCidadeTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gramado"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="-0.01"
                    android:lineSpacingMultiplier="1.05"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conteúdos da cidade"
                    android:textSize="12sp"
                    android:textColor="#A5D6A7"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp"
                    android:letterSpacing="0.03"/>

            </LinearLayout>

            <!-- Brasão circular com sombra -->
            <androidx.cardview.widget.CardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <ImageView
                    android:id="@+id/ivBrasaoCidade"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_dialog_map"
                    android:scaleType="fitCenter"
                    android:padding="4dp"/>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </FrameLayout>

    <!-- ══════════════════════════════════════════
         DESCRIÇÃO DA CIDADE
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="13dp"
        android:paddingBottom="10dp"
        android:background="#F2F5F0">

        <TextView
            android:id="@+id/txtDescricaoCidade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Explore informações, dicas e orientações sobre prevenção de desastres e segurança."
            android:textSize="13sp"
            android:textColor="#4E6553"
            android:lineSpacingExtra="3dp"/>

    </LinearLayout>

    <!-- Divisor sutil -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E8DC"
        android:layout_marginHorizontal="16dp"/>

    <!-- ══════════════════════════════════════════
         CHIPS DE CATEGORIA
         ══════════════════════════════════════════ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        android:background="#F2F5F0">

        <LinearLayout
            android:id="@+id/layoutChipsCategorias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"/>

    </HorizontalScrollView>

    <!-- ══════════════════════════════════════════
         LISTA DE CONTEÚDOS  /  ESTADO VAZIO
         ══════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Lista principal -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerConteudos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="88dp"
            android:nestedScrollingEnabled="true"/>

        <!-- Estado vazio -->
        <LinearLayout
            android:id="@+id/layoutVazio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@android:drawable/ic_menu_agenda"
                android:alpha="0.18"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nenhum conteúdo disponível"
                android:textSize="14sp"
                android:textColor="#BDBDBD"
                android:layout_marginTop="14dp"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

        <!-- ProgressBar centralizado -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="#2E7D32"/>

        <!-- FAB: novo conteúdo (admin) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabNovoConteudo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="Novo conteúdo"
            app:backgroundTint="#2E7D32"
            app:tint="#FFFFFF"
            app:elevation="10dp"
            android:visibility="gone"/>

    </FrameLayout>

</LinearLayout>