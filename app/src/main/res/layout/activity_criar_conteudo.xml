<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9"
    android:orientation="vertical">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#2E7D32"
        android:paddingTop="24dp"
        app:title="Novo Conteúdo"
        app:titleTextColor="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FAFFFE"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Badge perfil -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:letterSpacing="0.08"
                        android:text="📋  PERFIL PROJETO"
                        android:textColor="#1565C0"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:letterSpacing="0.08"
                        android:text="DADOS DO CONTEÚDO"
                        android:textColor="#388E3C"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <!-- TÍTULO -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:letterSpacing="0.08"
                        android:text="TÍTULO"
                        android:textColor="#388E3C"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutTitulo"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:boxBackgroundColor="#F1F8E9"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#C8E6C9">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTitulo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Ex: Educação Financeira"
                            android:inputType="textCapSentences"
                            android:padding="14dp"
                            android:textColor="#2E7D32"
                            android:textColorHint="#A5D6A7"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- DESCRIÇÃO -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:letterSpacing="0.08"
                        android:text="DESCRIÇÃO"
                        android:textColor="#388E3C"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutDescricao"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        app:boxBackgroundColor="#F1F8E9"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#C8E6C9">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editDescricao"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="top"
                            android:hint="Descreva brevemente o conteúdo..."
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="3"
                            android:padding="14dp"
                            android:textColor="#2E7D32"
                            android:textColorHint="#A5D6A7"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Divisória -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginBottom="20dp"
                        android:background="#E8F5E9" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:letterSpacing="0.08"
                        android:text="COR"
                        android:textColor="#388E3C"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerCor"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="16dp"
                        android:background="#F1F8E9" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:letterSpacing="0.08"
                        android:text="ÍCONE"
                        android:textColor="#388E3C"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerIcone"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginBottom="24dp"
                        android:background="#F1F8E9" />


                    <!-- Botão publicar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSalvar"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:letterSpacing="0.08"
                        android:text="PUBLICAR CONTEÚDO"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:backgroundTint="#2E7D32"
                        app:cornerRadius="14dp"
                        app:elevation="4dp" />

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="12dp"
                        android:indeterminateTint="#2E7D32"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
