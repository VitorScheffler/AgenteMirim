<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7F5"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#2E7D32"
        app:titleTextColor="#FFFFFF"
        app:title="Criar conteúdo"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="32dp">

            <!-- ── Card: Informações básicas ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Informações básicas"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="16dp"/>

                    <!-- Título -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutTitulo"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Título do conteúdo *"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#C8E6C9"
                        app:boxBackgroundColor="#F9FBF9">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTitulo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Ex: Como agir em caso de enchentes"
                            android:inputType="textCapSentences"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BDBDBD"
                            android:textSize="14sp"
                            android:padding="14dp"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Descrição curta -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutDescricao"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Descrição resumida *"
                        app:helperText="Aparece na listagem de conteúdos"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#C8E6C9"
                        app:boxBackgroundColor="#F9FBF9"
                        app:counterEnabled="true"
                        app:counterMaxLength="200">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editDescricao"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Breve resumo do conteúdo..."
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="2"
                            android:gravity="top"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BDBDBD"
                            android:textSize="14sp"
                            android:padding="14dp"
                            android:maxLength="200"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Texto completo do conteúdo -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutTexto"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Texto do conteúdo *"
                        app:helperText="Conteúdo completo exibido na tela de detalhe"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#C8E6C9"
                        app:boxBackgroundColor="#F9FBF9"
                        app:counterEnabled="true"
                        app:counterMaxLength="5000">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTexto"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Escreva aqui o conteúdo completo do artigo, dica ou notícia..."
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="6"
                            android:gravity="top"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BDBDBD"
                            android:textSize="14sp"
                            android:padding="14dp"
                            android:maxLength="5000"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Card: Tipo de conteúdo ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de conteúdo *"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/btnTipoDica"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_tipo_ativo"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_help" android:tint="#2E7D32"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Dica" android:textSize="11sp" android:textStyle="bold"
                                android:textColor="#2E7D32" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnTipoVideo"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_tipo_inativo"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:src="@android:drawable/ic_media_play" android:tint="#9E9E9E"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Vídeo" android:textSize="11sp" android:textColor="#9E9E9E"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnTipoNoticia"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_tipo_inativo"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_send" android:tint="#9E9E9E"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Notícia" android:textSize="11sp" android:textColor="#9E9E9E"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnTipoMaterial"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_tipo_inativo"
                            android:clickable="true"
                            android:focusable="true">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_agenda" android:tint="#9E9E9E"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Material" android:textSize="11sp" android:textColor="#9E9E9E"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Card: Categorias ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Categorias *"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1B5E20"/>

                        <TextView
                            android:id="@+id/txtCategoriasErro"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="#E53935"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selecione uma ou mais categorias relacionadas"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"
                        android:layout_marginBottom="14dp"/>

                    <!-- Linha 1: Enchente + Deslizamento -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <LinearLayout
                            android:id="@+id/chipEnchente"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="@drawable/bg_tipo_inativo">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌊"
                                android:textSize="16sp"
                                android:layout_marginEnd="6dp"/>
                            <TextView
                                android:id="@+id/lblEnchente"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Enchente"
                                android:textSize="12sp"
                                android:textColor="#9E9E9E"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/chipDeslizamento"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="@drawable/bg_tipo_inativo">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⛰️"
                                android:textSize="16sp"
                                android:layout_marginEnd="6dp"/>
                            <TextView
                                android:id="@+id/lblDeslizamento"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Deslizamento"
                                android:textSize="12sp"
                                android:textColor="#9E9E9E"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Linha 2: Tempestade + Outros -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/chipTempestade"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="@drawable/bg_tipo_inativo">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⛈️"
                                android:textSize="16sp"
                                android:layout_marginEnd="6dp"/>
                            <TextView
                                android:id="@+id/lblTempestade"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tempestade"
                                android:textSize="12sp"
                                android:textColor="#9E9E9E"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/chipOutros"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="@drawable/bg_tipo_inativo">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📋"
                                android:textSize="16sp"
                                android:layout_marginEnd="6dp"/>
                            <TextView
                                android:id="@+id/lblOutros"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Outros"
                                android:textSize="12sp"
                                android:textColor="#9E9E9E"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Card: Imagem de capa ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Imagem de capa (opcional)"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#1B5E20"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aparece no topo da tela de detalhe do conteúdo"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"
                        android:layout_marginBottom="12dp"/>

                    <!-- Preview da capa -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardPreviewCapa"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <ImageView
                                android:id="@+id/ivPreviewCapa"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"/>
                            <!-- Botão remover capa -->
                            <TextView
                                android:id="@+id/btnRemoverCapa"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="top|end"
                                android:layout_margin="8dp"
                                android:gravity="center"
                                android:text="✕"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:background="#88000000"
                                android:clickable="true"
                                android:focusable="true"/>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Área upload capa (some quando capa selecionada) -->
                    <LinearLayout
                        android:id="@+id/layoutUploadCapa"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_upload_area"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_camera"
                            android:tint="#2E7D32"
                            android:alpha="0.6"
                            android:layout_marginBottom="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toque para selecionar imagem de capa"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#388E3C"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="JPG, PNG (máx. 10MB)"
                            android:textSize="11sp"
                            android:textColor="#A5D6A7"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Card: Arquivos e materiais (múltiplos) ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Arquivos e materiais"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1B5E20"/>

                        <!-- Contador de arquivos -->
                        <TextView
                            android:id="@+id/txtContadorArquivos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 / 5"
                            android:textSize="12sp"
                            android:textColor="#9E9E9E"/>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PDF, MP4, JPG, PNG — até 5 arquivos"
                        android:textSize="12sp"
                        android:textColor="#9E9E9E"
                        android:layout_marginBottom="12dp"/>

                    <!-- Lista de arquivos selecionados -->
                    <LinearLayout
                        android:id="@+id/layoutArquivosSelecionados"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginBottom="10dp"/>

                    <!-- Botão adicionar arquivo -->
                    <LinearLayout
                        android:id="@+id/layoutUploadArquivo"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_upload_area"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_upload"
                            android:tint="#2E7D32"
                            android:alpha="0.6"
                            android:layout_marginBottom="6dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Toque para adicionar arquivo"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#388E3C"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PDF, MP4, JPG, PNG (máx. 50MB cada)"
                            android:textSize="11sp"
                            android:textColor="#A5D6A7"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botão publicar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="☁  Publicar conteúdo"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"
                app:backgroundTint="#2E7D32"
                app:cornerRadius="16dp"
                app:elevation="4dp"/>

            <TextView
                android:id="@+id/txtProgresso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:textSize="12sp"
                android:textColor="#66BB6A"
                android:visibility="gone"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                android:indeterminateTint="#2E7D32"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>